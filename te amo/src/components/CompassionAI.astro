---
---
<div class="bg-white/60 backdrop-blur-[10px] rounded-organic p-6 shadow-sm border border-white/40 flex flex-col relative overflow-hidden transition-all duration-500">
  
  <h3 class="text-xs font-bold text-gray-800 mb-4 flex items-center gap-2 uppercase tracking-widest">
    <span>✝️</span> Encuentro con Dios
  </h3>
  <p class="text-gray-500 text-sm mb-6">Un refugio seguro para descansar tu mente y sentir el profundo amor que Él tiene por ti.</p>

  <!-- Micro-Escapes: Estar con Dios -->
  <div>
    <button id="btn-escape" class="w-full py-4 bg-indigo-50 text-indigo-500 border border-indigo-100 rounded-2xl font-semibold text-sm hover:bg-indigo-100 transition-colors active:scale-[0.98] flex items-center justify-center gap-3 shadow-sm">
      <!-- Ícono de corazón -->
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="none">
        <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
      </svg>
      Llévame con Dios
    </button>
  </div>

  <!-- Response Display area -->
  <div id="ai-response-container" class="mt-6 hidden flex-col transition-all duration-500">
    <!-- Animación de carga -->
    <div id="ai-loading" class="hidden flex-col items-center justify-center py-6">
      <div class="relative w-12 h-12 flex items-center justify-center mb-4">
        <div class="absolute inset-0 bg-indigo-200 rounded-full animate-ping opacity-75"></div>
        <div class="relative w-8 h-8 bg-indigo-300 rounded-full shadow-[0_0_15px_rgba(165,180,252,0.6)]"></div>
      </div>
      <p class="text-sm text-indigo-400 font-medium animate-pulse">Preparando un lugar de paz...</p>
    </div>
    
    <!-- Resultado -->
    <div id="ai-result" class="hidden bg-white/80 border border-indigo-50 p-5 rounded-2xl text-gray-700 text-[15px] leading-relaxed shadow-sm space-y-3 font-medium">
    </div>
  </div>
</div>

<script>
  const btnEscape = document.getElementById('btn-escape');
  
  const responseContainer = document.getElementById('ai-response-container');
  const aiLoading = document.getElementById('ai-loading');
  const aiResult = document.getElementById('ai-result');

  async function fetchAI(action, text = '') {
    if(!responseContainer || !aiLoading || !aiResult) return;
    
    responseContainer.classList.remove('hidden');
    responseContainer.classList.add('flex');
    aiLoading.classList.remove('hidden');
    aiLoading.classList.add('flex');
    aiResult.classList.add('hidden');
    aiResult.classList.remove('block');

    // 1. Revisar caché para ahorrar cuota
    const cacheKey = `escape_cache_${action}`;
    const cached = localStorage.getItem(cacheKey);
    const now = Date.now();
    const ONE_HOUR = 60 * 60 * 1000;

    if (cached) {
      try {
        const parsed = JSON.parse(cached);
        if (now - parsed.timestamp < ONE_HOUR) {
          aiResult.innerHTML = `<p>${parsed.data}</p>`;
          aiResult.classList.remove('hidden');
          aiResult.classList.add('block');
          aiLoading.classList.add('hidden');
          aiLoading.classList.remove('flex');
          return;
        }
      } catch(e) {}
    }

    try {
      const res = await fetch('/api/ai', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action, text })
      });
      const data = await res.json();

      if (data.success) {
        // En caso de que Gemini devuelva saltos de línea (\n), los convertimos en párrafos legibles
        const formattedData = data.data.replace(/\n\n/g, '</p><p class="mt-3">');
        aiResult.innerHTML = `<p>${formattedData}</p>`;
        
        // Guardar en caché
        localStorage.setItem(cacheKey, JSON.stringify({ timestamp: now, data: formattedData }));
        
        aiResult.classList.remove('hidden');
        aiResult.classList.add('block');
      } else {
        aiResult.innerHTML = "<em>Hubo un error, pero recuerda que Él siempre está contigo, incluso ahora.</em>";
        aiResult.classList.remove('hidden');
        aiResult.classList.add('block');
      }
    } catch (e) {
      aiResult.innerHTML = "<em>No pudimos conectar en este momento, por favor respira profundo, Dios sigue a tu lado.</em>";
      aiResult.classList.remove('hidden');
      aiResult.classList.add('block');
    } finally {
      aiLoading.classList.add('hidden');
      aiLoading.classList.remove('flex');
    }
  }

  if(btnEscape) {
    btnEscape.addEventListener('click', () => {
      fetchAI('escape');
    });
  }
</script>
