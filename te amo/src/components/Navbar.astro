---
<nav class="w-full px-6 py-6 flex justify-between items-center z-10 relative">
  <div class="flex flex-col">
    <span id="greeting" class="text-2xl font-semibold text-gray-800 tracking-tight transition-opacity duration-500 opacity-0">Hola</span>
    <span class="text-sm text-gray-500 font-medium tracking-wide">Hoy te ves preciosa ✨</span>
  </div>
  <div class="p-3 bg-white/60 backdrop-blur-[10px] rounded-organic shadow-sm flex items-center justify-center border border-white/40">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-pink-400" fill="currentColor" viewBox="0 0 24 24" stroke="none">
      <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" />
    </svg>
  </div>
</nav>

<script>
  function updateGreeting() {
    const hour = new Date().getHours();
    let greetingText = 'Buen día';
    
    if (hour >= 12 && hour < 19) {
      greetingText = 'Buenas tardes';
    } else if (hour >= 19 || hour < 5) {
      greetingText = 'Buenas noches';
    }
    
    const greetingEl = document.getElementById('greeting');
    if (greetingEl) {
      greetingEl.textContent = greetingText;
      greetingEl.classList.remove('opacity-0');
    }
  }

  // Run immediately
  updateGreeting();
</script>
