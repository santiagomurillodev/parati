---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Bóveda de Análisis">
  <!-- Utilizamos flex con min-h-screen para centrar correctamente y permitir scroll sin cortarlo -->
  <div class="flex flex-col items-center justify-center p-6 min-h-screen relative w-full" id="admin-wrapper">
    
    <!-- Pantalla de Login: 1 solo input y diseño Glassmorphism coherente con el resto -->
    <div id="login-screen" class="w-full max-w-[20rem] bg-white/60 backdrop-blur-[10px] p-8 rounded-organic border border-white/40 shadow-sm flex flex-col items-center transition-all duration-500 z-10 my-auto">
      
      <div class="w-16 h-16 bg-pink-50 rounded-full mb-6 flex items-center justify-center shadow-inner shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-pink-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
      </div>
      
      <h1 class="text-xl font-semibold text-gray-800 mb-2 text-center">Acceso Restringido</h1>
      <p class="text-gray-500 text-sm mb-8 text-center">Introduce el PIN maestro.</p>
      
      <div class="w-full mb-6 relative">
        <input 
          id="single-pin-input" 
          type="password" 
          inputmode="numeric" 
          maxlength="6" 
          placeholder="••••••" 
          class="w-full bg-white/50 border border-white/60 rounded-2xl p-4 text-center text-2xl tracking-[0.4em] text-gray-800 focus:outline-none focus:ring-2 focus:ring-pink-300 transition-all placeholder:tracking-normal placeholder:text-gray-300 shadow-inner" 
        />
      </div>
      
      <p id="pin-error" class="text-rose-500 text-sm font-medium hidden opacity-0 transition-opacity min-h-[20px] text-center">Código incorrecto.</p>
    </div>

    <!-- Dashboard Screen -->
    <div id="dashboard-screen" class="w-full hidden flex-col transition-all duration-700 opacity-0 scale-95 z-10 py-6">
      
      <header class="flex items-center justify-between mb-8 bg-white/60 backdrop-blur-[10px] p-5 rounded-3xl border border-white/40 shadow-sm shrink-0">
        <div>
          <h1 class="text-2xl font-bold text-gray-800 tracking-tight">Panel Táctico</h1>
          <p class="text-pink-400 text-sm font-medium">Análisis y Estrategia</p>
        </div>
        <button id="btn-logout" class="p-3 bg-white/50 border border-white/60 text-gray-400 rounded-full hover:bg-pink-50 hover:text-pink-400 transition-colors shadow-sm shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
          </svg>
        </button>
      </header>

      <div class="flex-1 space-y-6 pb-4">
        
        <!-- Gráfica Minimalista de Estrés -->
        <div class="bg-white/60 backdrop-blur-[10px] p-6 rounded-[2.5rem] border border-white/40 shadow-sm shrink-0">
          <h3 class="text-gray-800 font-bold mb-6 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-pink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z" />
            </svg>
            Métricas de Bienestar (7 días)
          </h3>
          <p class="text-[10px] text-gray-400 mb-4 uppercase tracking-widest font-bold">Uso de Guía Bíblica y Victorias</p>
          
          <div class="flex items-end justify-between h-32 gap-3 mt-4">
            <!-- Barras CSS animadas -->
            <div class="w-full flex flex-col items-center gap-2 group">
              <div class="w-full bg-pink-100 rounded-full h-full relative overflow-hidden">
                <div class="absolute bottom-0 w-full bg-pink-300 rounded-full h-[30%] group-hover:bg-pink-400 transition-colors"></div>
              </div>
              <span class="text-[10px] text-gray-500 font-bold uppercase">L</span>
            </div>
            <div class="w-full flex flex-col items-center gap-2 group">
              <div class="w-full bg-pink-100 rounded-full h-full relative overflow-hidden">
                <div class="absolute bottom-0 w-full bg-pink-300 rounded-full h-[50%] group-hover:bg-pink-400 transition-colors"></div>
              </div>
              <span class="text-[10px] text-gray-500 font-bold uppercase">M</span>
            </div>
            <div class="w-full flex flex-col items-center gap-2 group">
              <div class="w-full bg-pink-100 rounded-full h-full relative overflow-hidden">
                <div class="absolute bottom-0 w-full bg-rose-400 rounded-full h-[80%] group-hover:bg-rose-500 transition-colors"></div>
              </div>
              <span class="text-[10px] text-gray-500 font-bold uppercase">X</span>
            </div>
            <div class="w-full flex flex-col items-center gap-2 group">
              <div class="w-full bg-pink-100 rounded-full h-full relative overflow-hidden">
                <div class="absolute bottom-0 w-full bg-rose-400 rounded-full h-[90%] group-hover:bg-rose-500 transition-colors"></div>
              </div>
              <span class="text-[10px] text-gray-500 font-bold uppercase">J</span>
            </div>
            <div class="w-full flex flex-col items-center gap-2 group">
              <div class="w-full bg-pink-100 rounded-full h-full relative overflow-hidden">
                <div class="absolute bottom-0 w-full bg-pink-300 rounded-full h-[40%] group-hover:bg-pink-400 transition-colors"></div>
              </div>
              <span class="text-[10px] text-gray-500 font-bold uppercase">V</span>
            </div>
            <div class="w-full flex flex-col items-center gap-2 group">
              <div class="w-full bg-pink-100 rounded-full h-full relative overflow-hidden">
                <div class="absolute bottom-0 w-full bg-emerald-300 rounded-full h-[20%] group-hover:bg-emerald-400 transition-colors"></div>
              </div>
              <span class="text-[10px] text-gray-500 font-bold uppercase">S</span>
            </div>
            <div class="w-full flex flex-col items-center gap-2 group">
              <div class="w-full bg-pink-100 rounded-full h-full relative overflow-hidden">
                <div class="absolute bottom-0 w-full bg-emerald-300 rounded-full h-[10%] group-hover:bg-emerald-400 transition-colors"></div>
              </div>
              <span class="text-[10px] text-gray-500 font-bold uppercase">D</span>
            </div>
          </div>
        </div>

        <!-- Registro de Actividad Reciente -->
        <div class="bg-white/60 backdrop-blur-[10px] p-6 rounded-[2.5rem] border border-white/40 shadow-sm shrink-0">
          <h3 class="text-gray-800 font-bold mb-4 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-pink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Actividad de Paz
          </h3>
          <div id="metrics-list" class="space-y-3">
            <!-- Cargado por JS -->
            <p class="text-xs text-gray-400 italic">No hay actividad registrada aún.</p>
          </div>
        </div>

        <!-- Analizador de IA -->
        <div class="bg-white/60 backdrop-blur-[10px] p-6 rounded-[2.5rem] border border-white/40 shadow-sm shrink-0">
          <h3 class="text-gray-800 font-bold mb-4 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
            Analizador Táctico IA
          </h3>
          <p class="text-xs text-gray-500 mb-5">Analiza el comportamiento emocional para sugerirte cómo apoyarla mejor este fin de semana.</p>
          
          <div id="ai-report-container" class="bg-white/50 rounded-[1.5rem] p-5 border border-white/60 min-h-[120px] flex items-center justify-center relative overflow-hidden">
            
            <button id="btn-generate-report" class="bg-indigo-50 text-indigo-500 px-6 py-3 rounded-full text-sm font-semibold hover:bg-indigo-100 transition-transform active:scale-95 shadow-sm flex items-center gap-2 z-10 border border-indigo-100">
              Generar Estrategia de Apoyo
            </button>

            <!-- Estado de Carga -->
            <div id="ai-loading" class="hidden absolute inset-0 bg-white/80 backdrop-blur-md flex items-center justify-center z-20">
              <div class="flex flex-col items-center gap-3">
                <span class="w-4 h-4 bg-indigo-400 rounded-full animate-ping"></span>
                <p class="text-[10px] text-indigo-500 font-bold tracking-widest uppercase">Analizando Datos Supabase...</p>
              </div>
            </div>

            <!-- Resultado -->
            <div id="ai-result" class="hidden w-full text-left z-10 flex-col gap-3">
              <div class="flex items-center gap-2 mb-1 border-b border-indigo-100/50 pb-2">
                <span class="w-2.5 h-2.5 bg-emerald-400 rounded-full animate-pulse shadow-[0_0_8px_rgba(52,211,153,0.6)]"></span>
                <p class="text-[10px] text-emerald-600 uppercase tracking-widest font-bold">Diagnóstico Completado</p>
              </div>
              <p id="ai-report-text" class="text-gray-700 text-[13px] leading-relaxed font-medium">
                <!-- Text loaded by JS -->
              </p>
            </div>
          </div>
        </div>
        
        <div class="mt-8 text-center shrink-0">
          <a href="/" class="text-xs text-gray-500 hover:text-pink-400 transition-colors uppercase tracking-widest font-bold block py-2">
            ← Volver al Front-end
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style is:global>
  .animate-shake {
    animation: shake 0.4s cubic-bezier(.36,.07,.19,.97) both;
  }
  @keyframes shake {
    10%, 90% { transform: translate3d(-2px, 0, 0); }
    20%, 80% { transform: translate3d(4px, 0, 0); }
    30%, 50%, 70% { transform: translate3d(-6px, 0, 0); }
    40%, 60% { transform: translate3d(6px, 0, 0); }
  }
</style>

<script>
  (function initAdmin() {
    const VALID_PIN = "123456"; 

    // DOM Elements
    const pinInput = document.getElementById('single-pin-input') as HTMLInputElement;
    const loginScreen = document.getElementById('login-screen');
    const dashboardScreen = document.getElementById('dashboard-screen');
    const pinError = document.getElementById('pin-error');
    const btnLogout = document.getElementById('btn-logout');
    
    // AI Analyzer Elements
    const btnGenerateReport = document.getElementById('btn-generate-report');
    const aiLoading = document.getElementById('ai-loading');
    const aiResult = document.getElementById('ai-result');
    const aiReportText = document.getElementById('ai-report-text');

    if (!loginScreen || !pinInput) return;

    // Lógica de Login
    pinInput.addEventListener('input', () => {
      pinInput.value = pinInput.value.replace(/[^0-9]/g, '');
      if (pinInput.value.length === 6) {
        checkPin();
      } else {
        hideError();
      }
    });

    function checkPin() {
      if (pinInput.value === VALID_PIN) {
        unlockDashboard();
      } else {
        showError();
      }
    }

    function showError() {
      if(pinError) {
        pinError.classList.remove('hidden');
        setTimeout(() => pinError.classList.remove('opacity-0'), 10);
      }
      
      loginScreen.classList.add('animate-shake');
      setTimeout(() => {
        loginScreen.classList.remove('animate-shake');
        pinInput.value = '';
        pinInput.focus();
      }, 400);
    }

    function hideError() {
      if(pinError) {
        pinError.classList.add('opacity-0');
        setTimeout(() => pinError.classList.add('hidden'), 300);
      }
    }

    function unlockDashboard() {
      loginScreen.classList.add('opacity-0', 'scale-95');
      setTimeout(() => {
        loginScreen.classList.add('hidden');
        
        if(dashboardScreen) {
          dashboardScreen.classList.remove('hidden');
          dashboardScreen.classList.add('flex');
          setTimeout(() => {
            dashboardScreen.classList.remove('opacity-0', 'scale-95');
            dashboardScreen.classList.add('opacity-100', 'scale-100');
          }, 50);
        }
      }, 500);
    }

    function loadMetrics() {
      const list = document.getElementById('metrics-list');
      if (!list) return;

      try {
        const metrics = JSON.parse(localStorage.getItem('user_metrics') || '[]');
        if (metrics.length === 0) return;

        list.innerHTML = '';
        metrics.slice(-5).reverse().forEach((m: any) => {
          const date = new Date(m.timestamp).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
          const item = document.createElement('div');
          item.className = 'flex items-center justify-between p-3 bg-white/40 rounded-xl border border-white/50';
          item.innerHTML = `
            <span class="text-xs font-medium text-gray-700">${m.action === 'bible_guidance' ? '📖 Buscó Guía Bíblica' : '🕊️ Encuentro con Dios'}</span>
            <span class="text-[10px] text-gray-400 font-bold">${date}</span>
          `;
          list.appendChild(item);
        });
      } catch(e) {}
    }

    if (btnLogout) {
      btnLogout.addEventListener('click', () => {
        pinInput.value = '';
        if(dashboardScreen) {
          dashboardScreen.classList.remove('opacity-100', 'scale-100');
          dashboardScreen.classList.add('opacity-0', 'scale-95');
          
          setTimeout(() => {
            dashboardScreen.classList.remove('flex');
            dashboardScreen.classList.add('hidden');
            if(loginScreen) {
              loginScreen.classList.remove('hidden');
              setTimeout(() => {
                loginScreen.classList.remove('opacity-0', 'scale-95');
                pinInput.focus();
              }, 50);
            }
          }, 500);
        }
      });
    }

    // Al desbloquear, cargar métricas
    const originalUnlock = unlockDashboard;
    unlockDashboard = () => {
      originalUnlock();
      loadMetrics();
    };

    // Lógica del Analizador IA
    if (btnGenerateReport) {
      btnGenerateReport.addEventListener('click', async () => {
        // Mostrar estado de carga
        btnGenerateReport.classList.add('hidden');
        if (aiLoading) {
          aiLoading.classList.remove('hidden');
          aiLoading.classList.add('flex');
        }
        
        try {
          // Extraer los datos REALES del usuario de localStorage
          let rawData = "El usuario no ha registrado ninguna victoria o tarea esta semana.";
          try {
            const victories = JSON.parse(localStorage.getItem('victories_history') || '[]');
            const metrics = JSON.parse(localStorage.getItem('user_metrics') || '[]');
            
            rawData = `Historial de hoy: 
            - Victorias/Hábitos: ${victories.length} completadas.
            - Consultas de Guía Bíblica: ${metrics.filter((m: any) => m.action === 'bible_guidance').length} veces.
            - Uso de Encuentro con Dios: ${metrics.filter((m: any) => m.action === 'escape').length} veces.`;
          } catch(e) { console.warn(e) }

          const response = await fetch('/api/ai', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action: 'generate_report', text: rawData })
          });
          
          const data = await response.json();
          
          if (data.success && aiReportText && aiResult) {
            aiReportText.innerText = data.data;
            if (aiLoading) {
              aiLoading.classList.add('hidden');
              aiLoading.classList.remove('flex');
            }
            aiResult.classList.remove('hidden');
            aiResult.classList.add('flex');
          }
        } catch (error) {
          console.error("Error contactando IA:", error);
          if (aiLoading) {
            aiLoading.classList.add('hidden');
            aiLoading.classList.remove('flex');
          }
          btnGenerateReport.classList.remove('hidden');
        }
      });
    }

    // Auto-focus al cargar la ruta
    setTimeout(() => {
      if(pinInput) pinInput.focus();
    }, 150);
  })();
</script>
